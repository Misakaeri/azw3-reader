<UserControl x:Class="Azw3Reader.App.Controls.BookReaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f5f5f5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#f0f0f0" Padding="8,4" BorderBrush="#e0e0e0" BorderThickness="0 0 0 1">
            <DockPanel LastChildFill="False">
                <!-- 章节名 -->
                <TextBlock x:Name="ChapterTitle" DockPanel.Dock="Left"
                           VerticalAlignment="Center" FontSize="12"
                           Margin="8,0" Foreground="#666"
                           MaxWidth="300" TextTrimming="CharacterEllipsis"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- 进度 -->
                    <TextBlock x:Name="ProgressText" VerticalAlignment="Center"
                               FontSize="11" Foreground="#999" Margin="0,0,8,0"/>

                    <Separator Width="1" Background="#ccc" Margin="4,2"/>

                    <!-- 字体 -->
                    <Button x:Name="FontSmallBtn" Content="A−" Width="28" Height="22"
                            FontSize="10" ToolTip="缩小字体"
                            Click="OnFontSmall" BorderThickness="0" Background="Transparent"/>
                    <Button x:Name="FontLargeBtn" Content="A+" Width="28" Height="22"
                            FontSize="10" ToolTip="放大字体"
                            Click="OnFontLarge" BorderThickness="0" Background="Transparent"/>

                    <Separator Width="1" Background="#ccc" Margin="4,2"/>

                    <!-- 主题 -->
                    <ComboBox x:Name="ThemeCombo" Width="90" Height="22" FontSize="11"
                              SelectionChanged="OnThemeChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 容器（在 OnLoaded 中动态创建 WebView2 控件，加速窗口显示） -->
        <Grid Grid.Row="1" x:Name="WebViewContainer"/>
    </Grid>
</UserControl>
